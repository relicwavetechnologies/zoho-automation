generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid()) @db.Uuid
  first_name        String         @db.VarChar(100)
  last_name         String         @db.VarChar(100)
  email             String         @unique @db.VarChar(255)
  password_hash     String         @db.VarChar(255)
  google_sub        String?        @unique @db.VarChar(255)
  is_email_verified Boolean        @default(false)
  created_at        DateTime       @default(now()) @db.Timestamptz
  updated_at        DateTime       @updatedAt @db.Timestamptz
  conversations     Conversation[]
  memberships       Membership[]
  invites_sent      Invite[]       @relation("InviteSender")
  audit_logs        AuditLog[]     @relation("AuditActor")
}

model Organization {
  id                 String                @id @default(uuid()) @db.Uuid
  name               String                @db.VarChar(255)
  created_at         DateTime              @default(now()) @db.Timestamptz
  updated_at         DateTime              @updatedAt @db.Timestamptz
  memberships        Membership[]
  invites            Invite[]
  integrations       OrganizationIntegration[]
  roles              Role[]
  tool_settings      OrganizationToolSetting[]
  audit_logs         AuditLog[]
}

model Membership {
  id              String       @id @default(uuid()) @db.Uuid
  user_id         String       @db.Uuid
  organization_id String       @db.Uuid
  role_key        String       @db.VarChar(50)
  status          String       @default("active") @db.VarChar(20)
  created_at      DateTime     @default(now()) @db.Timestamptz
  updated_at      DateTime     @updatedAt @db.Timestamptz
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  member_roles    MemberRole[]

  @@unique([user_id, organization_id])
}

model Role {
  id              String               @id @default(uuid()) @db.Uuid
  organization_id String?              @db.Uuid
  key             String               @db.VarChar(50)
  name            String               @db.VarChar(100)
  is_system       Boolean              @default(false)
  created_at      DateTime             @default(now()) @db.Timestamptz
  updated_at      DateTime             @updatedAt @db.Timestamptz
  organization    Organization?        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  permissions     RoleToolPermission[]
  member_roles    MemberRole[]

  @@unique([organization_id, key])
}

model MemberRole {
  id            String     @id @default(uuid()) @db.Uuid
  membership_id String     @unique @db.Uuid
  role_id       String     @db.Uuid
  status        String     @default("active") @db.VarChar(20)
  created_at    DateTime   @default(now()) @db.Timestamptz
  updated_at    DateTime   @updatedAt @db.Timestamptz
  membership    Membership @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
}

model RoleToolPermission {
  id                String   @id @default(uuid()) @db.Uuid
  role_id           String   @db.Uuid
  tool_key          String   @db.VarChar(100)
  can_execute       Boolean  @default(false)
  requires_approval Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz
  role              Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, tool_key])
}

model OrganizationToolSetting {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  tool_key        String       @db.VarChar(100)
  is_enabled      Boolean      @default(true)
  created_at      DateTime     @default(now()) @db.Timestamptz
  updated_at      DateTime     @updatedAt @db.Timestamptz
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, tool_key])
}

model Invite {
  id                 String       @id @default(uuid()) @db.Uuid
  organization_id    String       @db.Uuid
  email              String       @db.VarChar(255)
  role_key           String       @db.VarChar(50)
  token_hash         String       @db.VarChar(255)
  status             String       @default("pending") @db.VarChar(20)
  expires_at         DateTime     @db.Timestamptz
  accepted_at        DateTime?    @db.Timestamptz
  revoked_at         DateTime?    @db.Timestamptz
  invited_by_user_id String       @db.Uuid
  created_at         DateTime     @default(now()) @db.Timestamptz
  updated_at         DateTime     @updatedAt @db.Timestamptz
  organization       Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invited_by         User         @relation("InviteSender", fields: [invited_by_user_id], references: [id], onDelete: Cascade)
}

model OrganizationIntegration {
  id                   String       @id @default(uuid()) @db.Uuid
  organization_id      String       @db.Uuid
  provider             String       @db.VarChar(50)
  status               String       @db.VarChar(30)
  access_token         String?
  refresh_token        String?
  connected_at         DateTime?    @db.Timestamptz
  last_health_check_at DateTime?    @db.Timestamptz
  created_at           DateTime     @default(now()) @db.Timestamptz
  updated_at           DateTime     @updatedAt @db.Timestamptz
  organization         Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, provider])
}

model AuditLog {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  actor_user_id   String?      @db.Uuid
  action          String       @db.VarChar(120)
  target_type     String?      @db.VarChar(80)
  target_id       String?      @db.VarChar(120)
  metadata        Json?
  created_at      DateTime     @default(now()) @db.Timestamptz
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  actor           User?        @relation("AuditActor", fields: [actor_user_id], references: [id], onDelete: SetNull)
}

model Conversation {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @db.Uuid
  title         String    @default("New Conversation") @db.VarChar(500)
  model         String    @default("gpt-4o") @db.VarChar(100)
  system_prompt String?
  temperature   Float     @default(0.7)
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversation_id String       @db.Uuid
  role            String       @db.VarChar(20)
  content         String
  created_at      DateTime     @default(now()) @db.Timestamptz
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
}
