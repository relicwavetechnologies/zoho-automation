generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VectorVisibility {
  personal
  shared
  public
}

enum IngestionStatus {
  pending
  processing
  done
  failed
}

enum ScheduledWorkflowStatus {
  draft
  published
  active
  scheduled_active
  paused
  archived
}

enum ScheduledWorkflowScheduleType {
  one_time
  hourly
  daily
  weekly
  monthly
}

enum ScheduledWorkflowRunStatus {
  queued
  running
  succeeded
  failed
  cancelled
  skipped
  blocked
}

enum TaskStatus {
  pending
  running
  hitl
  done
  failed
  cancelled
}

enum UserMemoryKind {
  identity
  response_style
  preference
  constraint
  ongoing_task
  project
  decision
  tool_routing
}

enum UserMemoryScope {
  user_global
  thread_pinned
}

enum UserMemoryStatus {
  active
  archived
  forgotten
  superseded
}

enum UserMemorySource {
  user_explicit
  assistant_compacted
  tool_result
}

enum UserMemoryChannelOrigin {
  desktop
  lark
}

enum UserMemoryReplyLength {
  short
  balanced
  detailed
}

enum UserMemoryTone {
  neutral
  warm
  direct
}

enum UserMemoryFormatting {
  paragraphs
  bullets
}

model User {
  id                                 String                       @id @default(uuid())
  email                              String                       @unique
  password                           String
  name                               String?
  createdAt                          DateTime                     @default(now())
  updatedAt                          DateTime                     @updatedAt
  adminMemberships                   AdminMembership[]
  adminSessions                      AdminSession[]
  departmentMemberships              DepartmentMembership[]
  departmentUserToolOverrides        DepartmentUserToolOverride[]
  createdDepartmentAgentConfigs      DepartmentAgentConfig[]      @relation("DepartmentAgentConfigCreatedBy")
  updatedDepartmentAgentConfigs      DepartmentAgentConfig[]      @relation("DepartmentAgentConfigUpdatedBy")
  createdZohoConnectionProfiles      ZohoConnectionProfile[]      @relation("ZohoConnectionProfileCreatedBy")
  updatedZohoConnectionProfiles      ZohoConnectionProfile[]      @relation("ZohoConnectionProfileUpdatedBy")
  departmentToolPermissionsUpdated   DepartmentToolPermission[]   @relation("DepartmentToolPermissionUpdatedBy")
  departmentUserToolOverridesUpdated DepartmentUserToolOverride[] @relation("DepartmentUserToolOverrideUpdatedBy")
  memberSessions                     MemberSession[]
  desktopHandoffs                    DesktopAuthHandoff[]
  desktopThreads                     DesktopThread[]
  scheduledWorkflowsCreated          ScheduledWorkflow[]          @relation("ScheduledWorkflowCreatedBy")
  executionRuns                      ExecutionRun[]
  larkAuthLinks                      LarkUserAuthLink[]
  googleAuthLinks                    GoogleUserAuthLink[]
  memoryItems                        UserMemoryItem[]
  memoryProfiles                     UserMemoryProfile[]
  departmentPreference               UserDepartmentPreference?
}

model Company {
  id                     String                 @id @default(uuid())
  name                   String
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  departments            Department[]
  skills                 Skill[]
  zohoConnections        ZohoConnection[]
  zohoConnectionProfiles ZohoConnectionProfile[]
  zohoSyncJobs           ZohoSyncJob[]
  zohoOAuthConfig        ZohoOAuthConfig?
  larkTenantBindings     LarkTenantBinding[]
  larkWorkspaceConfig    LarkWorkspaceConfig?
  larkOperationalConfig  LarkOperationalConfig?
  larkDirectorySyncRuns  LarkDirectorySyncRun[]
  adminMemberships       AdminMembership[]
  adminSessions          AdminSession[]
  invites                CompanyInvite[]
  mcpActionLogs          McpActionLog[]
  channelIdentities      ChannelIdentity[]
  toolPermissions        ToolPermission[]
  toolActionPermissions  ToolActionPermission[]
  booksModulePermissions BooksModulePermission[]
  zohoRoleAccessPolicies ZohoRoleAccessPolicy[]
  aiRoleDefinitions      AiRoleDefinition[]
  vectorDocuments        VectorDocument[]
  vectorShareRequests    VectorShareRequest[]
  memberSessions         MemberSession[]
  desktopHandoffs        DesktopAuthHandoff[]
  desktopThreads         DesktopThread[]
  larkChatContexts       LarkChatContext[]
  scheduledWorkflows     ScheduledWorkflow[]
  executionRuns          ExecutionRun[]
  larkAuthLinks          LarkUserAuthLink[]
  googleAuthLinks        GoogleUserAuthLink[]
  googleWorkspaceAuth    CompanyGoogleAuthLink?
  fileAssets             FileAsset[]
  outboundArtifacts      OutboundArtifact[]
  userMemoryItems        UserMemoryItem[]
  userMemoryProfiles     UserMemoryProfile[]
  taskRuns               TaskRun[]
  userDepartmentPreferences UserDepartmentPreference[]
}

model UserDepartmentPreference {
  id                 String   @id @default(uuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeDepartmentId String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([companyId, userId])
  @@index([userId, companyId])
}

model TaskRun {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversationKey String
  channel         String
  status          TaskStatus @default(pending)
  inputMessage    Json
  currentStep     String?
  failureReason   String?
  requeueCount    Int        @default(0)
  lastHeartbeatAt DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([companyId, conversationKey, status])
  @@index([status, createdAt])
}

model UserMemoryItem {
  id              String                  @id @default(uuid())
  companyId       String
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId          String
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind            UserMemoryKind
  scope           UserMemoryScope
  channelOrigin   UserMemoryChannelOrigin
  threadId        String?
  conversationKey String?
  subjectKey      String
  summary         String
  valueJson       Json
  confidence      Float
  status          UserMemoryStatus        @default(active)
  source          UserMemorySource
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  lastConfirmedAt DateTime?
  staleAfterAt    DateTime?
  supersededById  String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([companyId, userId, status, kind, updatedAt])
  @@index([companyId, userId, subjectKey, status])
  @@index([companyId, userId, status, scope, threadId, conversationKey])
}

model UserMemoryProfile {
  id                      String                 @id @default(uuid())
  companyId               String
  company                 Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredReplyLength    UserMemoryReplyLength?
  preferredTone           UserMemoryTone?
  preferredFormatting     UserMemoryFormatting?
  updatedFromMemoryItemId String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@unique([companyId, userId])
}

model AdminMembership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, role, isActive])
  @@index([companyId, role, isActive])
}

model AdminSession {
  id        String    @id @default(uuid())
  sessionId String    @unique @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, role, expiresAt])
  @@index([companyId, role, expiresAt])
}

model ZohoConnection {
  id                    String           @id @default(uuid())
  companyId             String
  company               Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  environment           String           @default("prod")
  providerMode          String           @default("rest")
  status                String
  connectedAt           DateTime
  scopes                String[]
  lastSyncAt            DateTime?
  mcpBaseUrl            String?
  mcpApiKeyEncrypted    String?
  mcpWorkspaceKey       String?
  mcpAllowedTools       String[]
  mcpCapabilities       Json?
  mcpLastHealthAt       DateTime?
  mcpLastHealthStatus   String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenCipherVersion    Int              @default(1)
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenFailureCode      String?
  lastTokenRefreshAt    DateTime?
  tokenMetadata         Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  syncJobs              ZohoSyncJob[]
  vectorDocs            VectorDocument[]

  @@unique([companyId, environment])
}

model ZohoConnectionProfile {
  id                    String   @id @default(uuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profileName           String
  environment           String   @default("prod")
  connectionSource      String   @default("manual_token_set")
  status                String   @default("CONNECTED")
  isActive              Boolean  @default(false)
  connectedAt           DateTime?
  scopes                String[]
  clientId              String
  clientSecretEncrypted String
  redirectUri           String
  accountsBaseUrl       String   @default("https://accounts.zoho.com")
  apiBaseUrl            String   @default("https://www.zohoapis.com")
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenCipherVersion    Int      @default(1)
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenMetadata         Json?
  disabledAt            DateTime?
  createdBy             String
  createdByUser         User     @relation("ZohoConnectionProfileCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updatedBy             String
  updatedByUser         User     @relation("ZohoConnectionProfileUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, profileName])
  @@index([companyId, isActive, status])
}

model ZohoOAuthConfig {
  id                    String   @id @default(uuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId              String
  clientSecretEncrypted String
  redirectUri           String
  accountsBaseUrl       String   @default("https://accounts.zoho.com")
  apiBaseUrl            String   @default("https://www.zohoapis.com")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ChannelIdentity {
  id                 String   @id @default(uuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel            String
  externalUserId     String
  externalTenantId   String
  displayName        String?
  email              String?
  larkOpenId         String?
  larkUserId         String?
  sourceRoles        String[] @default([])
  aiRole             String   @default("MEMBER")
  aiRoleSource       String   @default("sync")
  syncedAiRole       String?
  syncedFromLarkRole String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([channel, externalUserId, companyId])
  @@index([companyId, larkOpenId])
  @@index([companyId, larkUserId])
  @@index([companyId, channel])
}

model LarkWorkspaceConfig {
  id                               String   @id @default(uuid())
  companyId                        String   @unique
  company                          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appId                            String
  appSecretEncrypted               String
  verificationTokenEncrypted       String?
  signingSecretEncrypted           String?
  staticTenantAccessTokenEncrypted String?
  apiBaseUrl                       String   @default("https://open.larksuite.com")
  createdBy                        String
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model LarkOperationalConfig {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultBaseAppToken String?
  defaultBaseTableId  String?
  defaultBaseViewId   String?
  defaultTasklistId   String?
  defaultCalendarId   String?
  defaultApprovalCode String?
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LarkDirectorySyncRun {
  id           String    @id @default(uuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trigger      String
  status       String
  syncedCount  Int       @default(0)
  adminCount   Int       @default(0)
  memberCount  Int       @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  diagnostics  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
}

model LarkTenantBinding {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  larkTenantKey String
  isActive      Boolean  @default(true)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([larkTenantKey])
  @@index([companyId, isActive])
}

model McpActionLog {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taskId      String
  actionName  String
  payloadHash String
  status      String
  receipt     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([taskId, createdAt])
}

model ZohoSyncJob {
  id               String             @id @default(uuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       ZohoConnection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobType          String
  status           String
  progressPercent  Int                @default(0)
  checkpoint       String?
  totalBatches     Int?
  processedBatches Int                @default(0)
  retryCount       Int                @default(0)
  maxAttempts      Int                @default(3)
  queuedAt         DateTime           @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?
  correlationId    String?
  payload          Json?
  errorMessage     String?
  events           ZohoSyncJobEvent[]

  @@index([companyId, status])
  @@index([connectionId, jobType, status])
}

model ZohoDeltaEvent {
  id         String   @id @default(uuid())
  companyId  String
  eventKey   String   @unique
  sourceType String
  sourceId   String
  operation  String
  changedAt  DateTime
  payload    Json?
  status     String
  attempts   Int      @default(0)
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, status])
}

model ZohoSyncJobEvent {
  id         String      @id @default(uuid())
  jobId      String
  job        ZohoSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  message    String?
  payload    Json?
  createdAt  DateTime    @default(now())

  @@index([jobId, createdAt])
}

model VectorDocument {
  id                     String           @id @default(uuid())
  companyId              String
  company                Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connectionId           String?
  connection             ZohoConnection?  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  fileAssetId            String?
  fileAsset              FileAsset?       @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  sourceType             String
  sourceId               String
  chunkIndex             Int
  documentKey            String?
  contentHash            String
  visibility             VectorVisibility @default(shared)
  ownerUserId            String?
  conversationKey        String?
  chunkText              String?
  payload                Json
  embedding              Float[]          @default([])
  embeddingSchemaVersion String?
  retrievalProfile       String?
  sourceUpdatedAt        DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([companyId, sourceType, sourceId, chunkIndex])
  @@index([companyId, sourceType])
  @@index([companyId, visibility, ownerUserId])
  @@index([companyId, conversationKey])
  @@index([fileAssetId])
  @@index([documentKey])
}

model FileAsset {
  id                     String             @id @default(uuid())
  companyId              String
  company                Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploaderUserId         String
  uploaderChannel        String // "lark" | "desktop"
  fileName               String
  mimeType               String
  sizeBytes              Int
  cloudinaryPublicId     String
  cloudinaryUrl          String
  cloudinaryResourceType String             @default("raw")
  ingestionStatus        IngestionStatus    @default(pending)
  ingestionError         String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  accessPolicies         FileAccessPolicy[]
  vectorDocs             VectorDocument[]
  outboundArtifacts      OutboundArtifact[]

  @@index([companyId, uploaderUserId])
  @@index([companyId, ingestionStatus])
}

model OutboundArtifact {
  id               String     @id @default(uuid())
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  sourceSystem     String
  sourceKind       String
  sourceRecordType String?
  sourceRecordId   String?
  sourceMetadata   Json?
  fileAssetId      String?
  fileAsset        FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  fileName         String
  mimeType         String
  sizeBytes        Int
  storageKind      String     @default("inline_base64")
  contentBase64    String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([companyId, createdAt])
  @@index([companyId, sourceSystem, sourceKind])
  @@index([companyId, sourceRecordType, sourceRecordId])
  @@index([fileAssetId])
}

model FileAccessPolicy {
  id          String    @id @default(uuid())
  fileAssetId String
  fileAsset   FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  companyId   String
  aiRole      String
  canRead     Boolean   @default(true)
  grantedBy   String
  createdAt   DateTime  @default(now())

  @@unique([fileAssetId, aiRole])
  @@index([companyId, aiRole])
}

model VectorShareRequest {
  id                         String    @id @default(uuid())
  companyId                  String
  company                    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requesterUserId            String
  requesterChannelIdentityId String?
  conversationKey            String
  status                     String
  reason                     String?
  decisionNote               String?
  reviewedBy                 String?
  reviewedAt                 DateTime?
  expiresAt                  DateTime?
  promotedVectorCount        Int       @default(0)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([companyId, status, createdAt])
  @@index([companyId, requesterUserId, conversationKey])
}

model IngressIdempotencyKey {
  id        String   @id @default(uuid())
  channel   String
  messageId String   @unique
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
}

model RbacPermission {
  id        String   @id @default(uuid())
  role      String
  action    String
  allowed   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String

  @@unique([role, action])
  @@index([role, allowed])
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  companyId String?
  action    String
  outcome   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model AdminControlState {
  id         String   @id @default(uuid())
  controlKey String
  companyId  String?
  value      String
  updatedBy  String
  updatedAt  DateTime @updatedAt

  @@unique([controlKey, companyId])
  @@index([companyId, updatedAt])
}

model CompanyInvite {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email      String
  role       String
  status     String
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([companyId, status, createdAt])
}

model Department {
  id                 String                       @id @default(uuid())
  companyId          String
  company            Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  description        String?
  status             String                       @default("active")
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  agentConfig        DepartmentAgentConfig?
  skills             Skill[]
  roles              DepartmentRole[]
  memberships        DepartmentMembership[]
  toolPermissions    DepartmentToolPermission[]
  userToolOverrides  DepartmentUserToolOverride[]
  desktopThreads     DesktopThread[]
  scheduledWorkflows ScheduledWorkflow[]

  @@unique([companyId, slug])
  @@index([companyId, status, updatedAt])
}

model Skill {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  scope        String
  name         String
  slug         String
  summary      String
  markdown     String
  tags         String[]    @default([])
  status       String      @default("active")
  isSystem     Boolean     @default(false)
  sortOrder    Int         @default(0)
  createdBy    String?
  updatedBy    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([companyId, scope, status, sortOrder])
  @@index([departmentId, status, sortOrder])
  @@index([companyId, scope, slug])
}

model DepartmentAgentConfig {
  id                String     @id @default(uuid())
  departmentId      String     @unique
  department        Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  systemPrompt      String
  skillsMarkdown    String
  zohoRateLimitJson Json?
  managerApprovalJson Json?
  isActive          Boolean    @default(true)
  createdBy         String
  createdByUser     User       @relation("DepartmentAgentConfigCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updatedBy         String
  updatedByUser     User       @relation("DepartmentAgentConfigUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([departmentId, isActive])
}

model DepartmentRole {
  id              String                     @id @default(uuid())
  departmentId    String
  department      Department                 @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  isSystem        Boolean                    @default(false)
  isDefault       Boolean                    @default(false)
  zohoReadScope   String                     @default("personalized")
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  memberships     DepartmentMembership[]
  toolPermissions DepartmentToolPermission[]
  booksModulePermissions BooksModulePermission[]

  @@unique([departmentId, slug])
  @@index([departmentId, isSystem, updatedAt])
}

model BooksModulePermission {
  id               String         @id @default(uuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentRoleId String
  departmentRole   DepartmentRole @relation(fields: [departmentRoleId], references: [id], onDelete: Cascade)
  module           String
  enabled          Boolean        @default(true)
  scopeOverride    String?
  updatedAt        DateTime       @updatedAt
  updatedBy        String?

  @@unique([companyId, departmentRoleId, module])
  @@index([companyId, departmentRoleId])
}

model DepartmentMembership {
  id           String         @id @default(uuid())
  departmentId String
  department   Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       String
  role         DepartmentRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  status       String         @default("active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([departmentId, userId])
  @@index([departmentId, status, updatedAt])
  @@index([userId, status, updatedAt])
  @@index([roleId, status])
}

model DepartmentToolPermission {
  id            String         @id @default(uuid())
  departmentId  String
  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  roleId        String
  role          DepartmentRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  toolId        String
  actionGroup   String         @default("all")
  allowed       Boolean        @default(true)
  updatedBy     String
  updatedByUser User           @relation("DepartmentToolPermissionUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  updatedAt     DateTime       @updatedAt

  @@unique([departmentId, roleId, toolId, actionGroup])
  @@index([departmentId, roleId])
}

model DepartmentUserToolOverride {
  id            String     @id @default(uuid())
