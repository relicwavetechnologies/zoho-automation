  toolId      String
  role        String
  actionGroup String
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@unique([companyId, toolId, role, actionGroup])
  @@index([companyId, toolId])
  @@index([companyId, role])
}

model ZohoRoleAccessPolicy {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role              String
  companyScopedRead Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@unique([companyId, role])
  @@index([companyId, role])
}

model AiRoleDefinition {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug        String
  displayName String
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, isBuiltIn])
}

model AiModelTargetConfig {
  id                  String   @id @default(uuid())
  targetKey           String   @unique
  provider            String
  modelId             String
  thinkingLevel       String?
  fastProvider        String?
  fastModelId         String?
  fastThinkingLevel   String?
  xtremeProvider      String?
  xtremeModelId       String?
  xtremeThinkingLevel String?
  updatedBy           String
  updatedAt           DateTime @updatedAt

  @@index([updatedAt])
}

// ─── Desktop / Member models ───

model MemberSession {
  id            String    @id @default(uuid())
  sessionId     String    @unique @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role          String    @default("MEMBER")
  channel       String    @default("desktop")
  authProvider  String    @default("password")
  larkTenantKey String?
  larkOpenId    String?
  larkUserId    String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId, channel, expiresAt])
  @@index([companyId, channel, expiresAt])
  @@index([companyId, larkOpenId])
}

model LarkUserAuthLink {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  larkTenantKey         String
  larkOpenId            String?
  larkUserId            String?
  larkEmail             String
  larkName              String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenType             String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenMetadata         Json?
  linkedAt              DateTime  @default(now())
  lastUsedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([userId, companyId])
  @@index([companyId, larkTenantKey])
  @@index([companyId, larkEmail])
}

model GoogleUserAuthLink {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
