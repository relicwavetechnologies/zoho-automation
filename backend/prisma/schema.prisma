  @@index([companyId, googleEmail])
  @@index([companyId, googleUserId])
}

model DesktopAuthHandoff {
  id         String    @id @default(uuid())
  code       String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role       String    @default("MEMBER")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([code, expiresAt])
}

model DesktopThread {
  id                 String           @id @default(uuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel            String           @default("desktop")
  canonicalThreadKey String?
  departmentId       String?
  department         Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  preferredEngine    String?
  title              String?
  summaryJson        Json?
  summaryUpdatedAt   DateTime?
  taskStateJson      Json?
  taskStateUpdatedAt DateTime?
  lastMessageAt      DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  messages           DesktopMessage[]

  @@unique([companyId, userId, channel, canonicalThreadKey])
  @@index([userId, companyId, channel, updatedAt])
  @@index([departmentId, channel, updatedAt])
}

model LarkChatContext {
  id                 String    @id @default(uuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chatId             String
  channel            String    @default("lark")
  chatType           String?
  summaryJson        Json?
  summaryUpdatedAt   DateTime?
  taskStateJson      Json?
  taskStateUpdatedAt DateTime?
  recentMessagesJson Json?
  sourceMessageCount Int       @default(0)
  lastMessageAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([companyId, channel, chatId])
  @@index([companyId, channel, updatedAt])
}

model DesktopMessage {
  id        String        @id @default(uuid())
  threadId  String
  thread    DesktopThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}

model ScheduledWorkflow {
  id                    String                        @id @default(uuid())
  companyId             String
  company               Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId          String?
  department            Department?                   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdByUserId       String?
  createdByUser         User?                         @relation("ScheduledWorkflowCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  name                  String
  status                ScheduledWorkflowStatus       @default(draft)
  userIntent            String
  aiDraft               String?
  workflowSpecJson      Json
  compiledPrompt        String
  capabilitySummaryJson Json
  timezone              String
  scheduleType          ScheduledWorkflowScheduleType
  scheduleConfigJson    Json
  scheduleEnabled       Boolean                       @default(false)
  nextRunAt             DateTime?
  lastRunAt             DateTime?
  outputConfigJson      Json
  originChatId          String?
  approvalGrantJson     Json?
  publishedAt           DateTime?
  pausedAt              DateTime?
  archivedAt            DateTime?
  claimToken            String?
  claimedAt             DateTime?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  runs                  ScheduledWorkflowRun[]
  messages              ScheduledWorkflowMessage[]

  @@index([companyId, status, updatedAt])
  @@index([companyId, status, nextRunAt])
  @@index([departmentId, status, updatedAt])
  @@index([status, nextRunAt])
  @@index([claimedAt])
}

model ScheduledWorkflowMessage {
  id         String            @id @default(uuid())
  workflowId String
  workflow   ScheduledWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  role       String
  content    String
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([workflowId, createdAt])
}

model ScheduledWorkflowRun {
  id                 String                     @id @default(uuid())
  workflowId         String
  workflow           ScheduledWorkflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status             ScheduledWorkflowRunStatus @default(queued)
  scheduledFor       DateTime
  startedAt          DateTime?
  finishedAt         DateTime?
  executionRunId     String?
  queueJobId         String?
  attemptNumber      Int                        @default(1)
  resultSummary      String?
  errorSummary       String?
  deliveryStatusJson Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([workflowId, scheduledFor])
  @@index([workflowId, createdAt])
  @@index([status, scheduledFor])
  @@index([executionRunId])
}

model AiTokenUsage {
  id                    String   @id @default(uuid())
  userId                String
  companyId             String
  agentTarget           String // e.g. 'mastra.supervisor'
  modelId               String // e.g. 'gpt-4.1-mini'
  provider              String // 'openai' | 'google'
  channel               String // 'desktop' | 'lark' | 'web'
  threadId              String?
  estimatedInputTokens  Int      @default(0)
  estimatedOutputTokens Int      @default(0)
  // Actual token counts from AI SDK response (if available)
  actualInputTokens     Int?
  actualOutputTokens    Int?
  wasCompacted          Boolean  @default(false)
  mode                  String   @default("high") // 'fast' | 'high' | 'xtreme'
  createdAt             DateTime @default(now())

  @@index([userId, companyId, createdAt])
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([companyId, modelId, createdAt])
}

model ExecutionRun {
  id            String           @id @default(uuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel       String
  entrypoint    String
  requestId     String?          @unique
  taskId        String?
  threadId      String?
  chatId        String?
  messageId     String?
  mode          String?
  agentTarget   String?
  status        String           @default("running")
  latestSummary String?
  errorCode     String?
  errorMessage  String?
  lastSequence  Int              @default(0)
  startedAt     DateTime         @default(now())
  finishedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  events        ExecutionEvent[]
  stepResults   StepResult[]

  @@index([companyId, startedAt])
  @@index([userId, startedAt])
  @@index([channel, startedAt])
  @@index([mode, startedAt])
  @@index([status, startedAt])
  @@index([taskId])
  @@index([threadId])
}

model ExecutionEvent {
  id          String       @id @default(uuid())
  executionId String
  execution   ExecutionRun @relation(fields: [executionId], references: [id], onDelete: Cascade)
  sequence    Int
  phase       String
  eventType   String
  actorType   String
  actorKey    String?
  title       String
  summary     String?
  status      String?
  payload     Json?
  createdAt   DateTime     @default(now())

  @@unique([executionId, sequence])
  @@index([executionId, createdAt])
  @@index([createdAt])
}

model StepResult {
  id             String       @id @default(uuid())
  executionId    String
  execution      ExecutionRun @relation(fields: [executionId], references: [id], onDelete: Cascade)
  sequence       Int
  toolName       String
  actorKey       String?
  title          String?
  success        Boolean
  status         String?
  authorityLevel String?
  resolvedIds    Json?
  entityIndexes  Json?
  summary        String?
  rawOutput      Json?
  createdAt      DateTime     @default(now())

  @@unique([executionId, sequence])
  @@index([executionId, createdAt])
}

model RuntimeConversation {
  id                     String                       @id @default(uuid())
  companyId              String
  departmentId           String?
  channel                String
  channelConversationKey String
  rawChannelKey          String
  createdByUserId        String?
  createdByEmail         String?
  title                  String?
  status                 String                       @default("active")
  refsJson               Json?
  lastMessageSequence    Int                          @default(0)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  messages               RuntimeConversationMessage[]
  runs                   RuntimeRun[]
  approvals              RuntimeApproval[]
  parityReports          RuntimeShadowParityReport[]

  @@unique([companyId, channel, channelConversationKey])
  @@index([companyId, updatedAt])
  @@index([companyId, channel, updatedAt])
  @@index([departmentId, updatedAt])
}

model RuntimeConversationMessage {
  id              String              @id @default(uuid())
  conversationId  String
  conversation    RuntimeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  runId           String?
  run             RuntimeRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)
  sequence        Int
  role            String
  messageKind     String
  sourceChannel   String
  sourceMessageId String?
  dedupeKey       String?
  contentText     String?
  contentJson     Json?
  attachmentsJson Json?
  toolCallJson    Json?
  toolResultJson  Json?
  visibility      String              @default("internal")
  createdAt       DateTime            @default(now())

  @@unique([conversationId, sequence])
  @@index([conversationId, createdAt])
  @@index([runId, createdAt])
  @@index([dedupeKey])
}

model RuntimeRun {
  id             String                       @id @default(uuid())
  conversationId String
  conversation   RuntimeConversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentRunId    String?
  engine         String                       @default("langgraph")
  engineMode     String                       @default("primary")
  channel        String
  entrypoint     String
  status         String                       @default("running")
  currentNode    String?
  stepCount      Int                          @default(0)
  maxSteps       Int                          @default(12)
  stopReason     String?
  errorJson      Json?
  traceJson      Json?
  metadataJson   Json?
  startedAt      DateTime                     @default(now())
  finishedAt     DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  messages       RuntimeConversationMessage[]
  approvals      RuntimeApproval[]
  snapshots      RuntimeSnapshot[]
  parityReports  RuntimeShadowParityReport[]

  @@index([conversationId, startedAt])
  @@index([parentRunId])
  @@index([channel, startedAt])
  @@index([status, startedAt])
}

model RuntimeApproval {
  id                  String              @id @default(uuid())
  conversationId      String
  conversation        RuntimeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  runId               String
  run                 RuntimeRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  externalActionId    String?
  toolId              String
  actionGroup         String
  kind                String
  summary             String
  subject             String?
  payloadJson         Json
  metadataJson        Json?
  riskLevel           String?
  status              String              @default("pending")
  channel             String
  requestedBy         String?
  approvedBy          String?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  expiresAt           DateTime?
  executionResultJson Json?
  idempotencyKey      String?
  decisionMessageId   String?
  resolutionReason    String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([conversationId, createdAt])
  @@index([runId, createdAt])
  @@index([status, createdAt])
  @@index([externalActionId])
  @@index([idempotencyKey])
}

model RuntimeSnapshot {
  id        String     @id @default(uuid())
  runId     String
  run       RuntimeRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepIndex Int
  nodeName  String
  stateJson Json
  createdAt DateTime   @default(now())

  @@index([runId, createdAt])
  @@index([runId, stepIndex])
}

model RuntimeShadowParityReport {
  id               String               @id @default(uuid())
  conversationId   String?
  conversation     RuntimeConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  runId            String?
  run              RuntimeRun?          @relation(fields: [runId], references: [id], onDelete: SetNull)
  channel          String
  baselineEngine   String
  candidateEngine  String
  baselineSummary  String?
  candidateSummary String?
  diffSummary      String?
  metricsJson      Json?
  createdAt        DateTime             @default(now())

  @@index([conversationId, createdAt])
  @@index([runId, createdAt])
  @@index([channel, createdAt])
}

model MemberTokenPolicy {
  id                String   @id @default(uuid())
  userId            String   @unique
  companyId         String
  monthlyTokenLimit Int      @default(2000000) // 2M tokens/month default
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companyId])
}
