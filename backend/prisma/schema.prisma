generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VectorVisibility {
  personal
  shared
  public
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  adminMemberships AdminMembership[]
  adminSessions    AdminSession[]
  memberSessions   MemberSession[]
  desktopHandoffs  DesktopAuthHandoff[]
  desktopThreads   DesktopThread[]
  larkAuthLinks    LarkUserAuthLink[]
}

model Company {
  id              String           @id @default(uuid())
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  zohoConnections ZohoConnection[]
  zohoSyncJobs    ZohoSyncJob[]
  zohoOAuthConfig ZohoOAuthConfig?
  larkTenantBindings LarkTenantBinding[]
  larkWorkspaceConfig LarkWorkspaceConfig?
  larkDirectorySyncRuns LarkDirectorySyncRun[]
  adminMemberships AdminMembership[]
  adminSessions    AdminSession[]
  invites          CompanyInvite[]
  mcpActionLogs    McpActionLog[]
  channelIdentities ChannelIdentity[]
  toolPermissions  ToolPermission[]
  aiRoleDefinitions AiRoleDefinition[]
  vectorDocuments  VectorDocument[]
  vectorShareRequests VectorShareRequest[]
  memberSessions   MemberSession[]
  desktopHandoffs  DesktopAuthHandoff[]
  desktopThreads   DesktopThread[]
  larkAuthLinks    LarkUserAuthLink[]
}

model AdminMembership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, role, isActive])
  @@index([companyId, role, isActive])
}

model AdminSession {
  id        String   @id @default(uuid())
  sessionId String   @unique @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, role, expiresAt])
  @@index([companyId, role, expiresAt])
}

model ZohoConnection {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  environment String      @default("prod")
  providerMode String     @default("rest")
  status      String
  connectedAt DateTime
  scopes      String[]
  lastSyncAt  DateTime?
  mcpBaseUrl  String?
  mcpApiKeyEncrypted String?
  mcpWorkspaceKey String?
  mcpAllowedTools String[]
  mcpCapabilities Json?
  mcpLastHealthAt DateTime?
  mcpLastHealthStatus String?
  accessTokenEncrypted String?
  refreshTokenEncrypted String?
  tokenCipherVersion Int @default(1)
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  tokenFailureCode String?
  lastTokenRefreshAt DateTime?
  tokenMetadata Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  syncJobs    ZohoSyncJob[]
  vectorDocs  VectorDocument[]

  @@unique([companyId, environment])
}

model ZohoOAuthConfig {
  id                    String   @id @default(uuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId              String
  clientSecretEncrypted String
  redirectUri           String
  accountsBaseUrl       String   @default("https://accounts.zoho.com")
  apiBaseUrl            String   @default("https://www.zohoapis.com")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ChannelIdentity {
  id               String   @id @default(uuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel          String
  externalUserId   String
  externalTenantId String
  displayName      String?
  email            String?
  larkOpenId       String?
  larkUserId       String?
  sourceRoles      String[] @default([])
  aiRole           String   @default("MEMBER")
  aiRoleSource     String   @default("sync")
  syncedAiRole     String?
  syncedFromLarkRole String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([channel, externalUserId, companyId])
  @@index([companyId, larkOpenId])
  @@index([companyId, larkUserId])
  @@index([companyId, channel])
}

model LarkWorkspaceConfig {
  id                           String   @id @default(uuid())
  companyId                    String   @unique
  company                      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appId                        String
  appSecretEncrypted           String
  verificationTokenEncrypted   String?
  signingSecretEncrypted       String?
  staticTenantAccessTokenEncrypted String?
  apiBaseUrl                   String   @default("https://open.larksuite.com")
  createdBy                    String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model LarkDirectorySyncRun {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trigger       String
  status        String
  syncedCount   Int      @default(0)
  adminCount    Int      @default(0)
  memberCount   Int      @default(0)
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?
  diagnostics   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
}

model LarkTenantBinding {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  larkTenantKey String
  isActive     Boolean  @default(true)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([larkTenantKey])
  @@index([companyId, isActive])
}

model McpActionLog {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taskId        String
  actionName    String
  payloadHash   String
  status        String
  receipt       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([taskId, createdAt])
}

model ZohoSyncJob {
  id            String         @id @default(uuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connectionId  String
  connection    ZohoConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobType       String
  status        String
  progressPercent Int       @default(0)
  checkpoint    String?
  totalBatches  Int?
  processedBatches Int      @default(0)
  retryCount    Int           @default(0)
  maxAttempts   Int           @default(3)
  queuedAt      DateTime       @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  correlationId String?
  payload       Json?
  errorMessage  String?
  events        ZohoSyncJobEvent[]

  @@index([companyId, status])
  @@index([connectionId, jobType, status])
}

model ZohoDeltaEvent {
  id         String   @id @default(uuid())
  companyId  String
  eventKey   String   @unique
  sourceType String
  sourceId   String
  operation  String
  changedAt  DateTime
  payload    Json?
  status     String
  attempts   Int      @default(0)
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, status])
}

model ZohoSyncJobEvent {
  id         String      @id @default(uuid())
  jobId      String
  job        ZohoSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  message    String?
  payload    Json?
  createdAt  DateTime    @default(now())

  @@index([jobId, createdAt])
}

model VectorDocument {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connectionId String?
  connection   ZohoConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sourceType   String
  sourceId     String
  chunkIndex   Int
  contentHash  String
  visibility   VectorVisibility @default(shared)
  ownerUserId  String?
  conversationKey String?
  payload      Json
  embedding    Float[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([companyId, sourceType, sourceId, chunkIndex])
  @@index([companyId, sourceType])
  @@index([companyId, visibility, ownerUserId])
  @@index([companyId, conversationKey])
}

model VectorShareRequest {
  id                       String   @id @default(uuid())
  companyId                String
  company                  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requesterUserId          String
  requesterChannelIdentityId String?
  conversationKey          String
  status                   String
  reason                   String?
  decisionNote             String?
  reviewedBy               String?
  reviewedAt               DateTime?
  expiresAt                DateTime?
  promotedVectorCount      Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([companyId, status, createdAt])
  @@index([companyId, requesterUserId, conversationKey])
}

model IngressIdempotencyKey {
  id        String   @id @default(uuid())
  channel   String
  messageId String   @unique
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
}

model RbacPermission {
  id        String   @id @default(uuid())
  role      String
  action    String
  allowed   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String

  @@unique([role, action])
  @@index([role, allowed])
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  companyId String?
  action    String
  outcome   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model AdminControlState {
  id        String   @id @default(uuid())
  controlKey String
  companyId String?
  value     String
  updatedBy String
  updatedAt DateTime @updatedAt

  @@unique([controlKey, companyId])
  @@index([companyId, updatedAt])
}

model CompanyInvite {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email      String
  role       String
  status     String
  token      String   @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, status, createdAt])
}

model ToolPermission {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  toolId    String
  role      String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([companyId, toolId, role])
  @@index([companyId, toolId])
}

model AiRoleDefinition {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug        String
  displayName String
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, isBuiltIn])
}

model AiModelTargetConfig {
  id            String   @id @default(uuid())
  targetKey      String   @unique
  provider       String
  modelId        String
  thinkingLevel  String?
  updatedBy      String
  updatedAt      DateTime @updatedAt

  @@index([updatedAt])
}

// ─── Desktop / Member models ───

model MemberSession {
  id        String    @id @default(uuid())
  sessionId String    @unique @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String    @default("MEMBER")
  channel   String    @default("desktop")
  authProvider String @default("password")
  larkTenantKey String?
  larkOpenId String?
  larkUserId String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, channel, expiresAt])
  @@index([companyId, channel, expiresAt])
  @@index([companyId, larkOpenId])
}

model LarkUserAuthLink {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  larkTenantKey         String
  larkOpenId            String?
  larkUserId            String?
  larkEmail             String
  larkName              String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenType             String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenMetadata         Json?
  linkedAt              DateTime @default(now())
  lastUsedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId, larkTenantKey])
  @@index([companyId, larkEmail])
}

model DesktopAuthHandoff {
  id         String    @id @default(uuid())
  code       String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role       String    @default("MEMBER")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([code, expiresAt])
}

model DesktopThread {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title         String?
  lastMessageAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      DesktopMessage[]

  @@index([userId, companyId, updatedAt])
}

model DesktopMessage {
  id        String        @id @default(uuid())
  threadId  String
  thread    DesktopThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}
