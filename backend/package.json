{
  "name": "enterprise-express-backend-template",
  "version": "1.0.0",
  "main": "dist/server.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && NODE_OPTIONS=--max-old-space-size=4096 tsc --noCheck && rm -rf dist/generated/prisma && mkdir -p dist/generated && cp -R src/generated/prisma dist/generated/prisma",
    "build:lean": "prisma generate && NODE_OPTIONS=--max-old-space-size=3072 tsc --noCheck --incremental --tsBuildInfoFile .tsbuildinfo && rm -rf dist/generated/prisma && mkdir -p dist/generated && cp -R src/generated/prisma dist/generated/prisma",
    "build:start": "pnpm run build:lean && pnpm run start",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "typecheck:vercel": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.vercel.json --noEmit",
    "smoke:vercel": "tsx --eval \"import './src/modules/desktop-chat/vercel-desktop.engine.ts'; import './src/modules/desktop-chat/desktop-chat.controller.ts'; console.log('vercel-runtime-ok')\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "admin:bootstrap:default": "prisma generate && node scripts/bootstrap-super-admin.cjs",
    "lark:token": "node scripts/generate-lark-tenant-token.cjs",
    "lark:docs:validate": "node scripts/validate-lark-docs.cjs",
    "test:unit:config": "node --test tests/env-contract.test.cjs && node --test tests/bootstrap-health.test.cjs",
    "test:unit:lark": "node --test tests/lark-*.test.cjs",
    "test:unit:zoho": "node --test tests/zoho-*.test.cjs tests/qdrant*.test.cjs tests/embedding*.test.cjs tests/google-ranking*.test.cjs",
    "test:unit:rag": "node --import tsx --test tests/embedding.service.test.cjs tests/qdrant.adapter.test.cjs tests/google-ranking.service.test.cjs tests/resilience.qdrant.test.cjs",
    "test:resilience": "node --test tests/resilience.*.test.cjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@langchain/google": "^0.1.5",
    "@langchain/openai": "^1.2.12",
    "@prisma/client": "^6.1.0",
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5",
    "ai": "^6.0.116",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "5.9.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "jose": "4.15.5",
      "execa": "8.0.1"
    }
  }
}
