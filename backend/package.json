{
  "name": "enterprise-express-backend-template",
  "version": "1.0.0",
  "main": "dist/server.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc && mkdir -p dist/generated && cp -R src/generated/prisma dist/generated/prisma",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "admin:bootstrap:default": "prisma generate && node scripts/bootstrap-super-admin.cjs",
    "lark:token": "node scripts/generate-lark-tenant-token.cjs",
    "test:unit:config": "node --test tests/env-contract.test.cjs && node --test tests/bootstrap-health.test.cjs",
    "test:unit:lark": "node --test tests/lark-*.test.cjs",
    "test:unit:v1": "node --test tests/langgraph-*.test.cjs tests/langchain-*.test.cjs",
    "test:unit:zoho": "node --test tests/zoho-*.test.cjs tests/qdrant*.test.cjs tests/embedding*.test.cjs",
    "test:resilience": "node --test tests/resilience.*.test.cjs",
    "validate:rollback:langgraph": "node scripts/validate-v1-rollback-drill.cjs --expected-engine=langgraph",
    "validate:rollback:legacy": "node scripts/validate-v1-rollback-drill.cjs --expected-engine=legacy"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@langchain/core": "^1.1.30",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.12",
    "@mastra/core": "^1.9.0",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "5.9.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
